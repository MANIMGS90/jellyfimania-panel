# Copia este archivo como ".env" y ajusta los valores.
# En Render, estos se configuran en Dashboard > Environment, NO subas
# tu .env real a GitHub.

# Usuario/contraseña del Super Admin (se crea solo, la PRIMERA vez
# que arranca el panel con una base de datos vacia).
ADMIN_USER=admin
ADMIN_PASS=cambia-esta-clave-ya

# Secreto para firmar los tokens de sesion (JWT). Pon algo largo y
# aleatorio, distinto en cada instalacion.
JWT_SECRET=cambia-este-secreto-por-uno-largo-y-random

# Puerto (Render lo asigna solo via variable de entorno PORT,
# normalmente no hace falta tocar esto).
PORT=4200
